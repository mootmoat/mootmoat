---
import { getLocaleFromUrl } from "@/docs/js/localeUtils";
import { getTranslatedData, useTranslations } from "@/docs/js/translationUtils";
import DocsLandingLayout from "@/docs/layouts/DocsLandingLayout.astro";
import Button from "@/docs/components/button/Button.astro";

const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
const t = useTranslations(currLocale);
---

<DocsLandingLayout title={siteData.title} description={siteData.description}>
  <main
    class="flex min-h-screen flex-col items-center justify-center overflow-hidden p-8 text-center"
  >
    <h1 class="font-heading text-base-900 dark:text-base-100 mb-4 text-4xl font-bold md:text-6xl">
      {t("hero_title")}
    </h1>
    <p class="text-base-500 dark:text-base-400 mb-8 max-w-2xl text-xl">{t("hero_description")}</p>

    <div class="flex gap-4">
      <Button
        href="/fr/docs/executive-briefing_-the-sovereign-engineering-entity/"
        variant="primary">Read Executive Briefing</Button
      >
      <Button href="/fr/docs/mootmoat-v17-implementation-study-guide/" variant="ghost"
        >View the Documentation Index</Button
      >
    </div>
  </main>
</DocsLandingLayout>
